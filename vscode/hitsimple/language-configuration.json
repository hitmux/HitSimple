{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "[",
      "close": "]",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "(",
      "close": ")",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*\\$\\s*(?:if|ifdef|ifndef)\\b",
      "end": "^\\s*\\$\\s*endif\\b"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}]*$|^\\s*\\$\\s*(?:if|ifdef|ifndef|elif|else)\\b.*$",
    "decreaseIndentPattern": "^\\s*\\}|^\\s*\\$\\s*(?:elif|else|endif)\\b.*$"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#%^&*()+=[{\\]}\\\\|;:'\",.<>/?\\s]+)"
}
