{
  "name": "hitsimple-vscode",
  "displayName": "HitSimple",
  "description": "HitSimple language support for VS Code: syntax highlighting, snippets, diagnostics, Build/Run, and native platform debugging.",
  "version": "0.2.2",
  "publisher": "hitmux",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hitmux/HitSimple.git"
  },
  "main": "./src/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "extensionDependencies": [
    "ms-vscode.cpptools"
  ],
  "scripts": {
    "test": "node --test test/extension.test.mjs test/workflow.test.mjs",
    "test:extension": "node test/run-extension-host.mjs",
    "verify:vsix": "vsce ls --tree",
    "package:vsix": "node scripts/package-vsix.js"
  },
  "devDependencies": {
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.2.0"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Debuggers"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Syntax highlighting remains available, but Build, Run, and Debug execute configured tools.",
      "restrictedConfigurations": [
        "hitsimple.compilerPath",
        "hitsimple.mode",
        "hitsimple.outputDirectory",
        "hitsimple.additionalArgs",
        "hitsimple.gdbPath",
        "hitsimple.lldbPath",
        "hitsimple.debugArguments"
      ]
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "hitsimple.buildCurrentFile",
        "title": "Build Current File",
        "category": "HitSimple",
        "enablement": "editorLangId == hitsimple && processExecutionSupported && isWorkspaceTrusted && !virtualWorkspace"
      },
      {
        "command": "hitsimple.runCurrentFile",
        "title": "Run Current File",
        "category": "HitSimple",
        "enablement": "editorLangId == hitsimple && processExecutionSupported && isWorkspaceTrusted && !virtualWorkspace"
      },
      {
        "command": "hitsimple.debugCurrentFile",
        "title": "Debug Current File",
        "category": "HitSimple",
        "enablement": "editorLangId == hitsimple && processExecutionSupported && isWorkspaceTrusted && !virtualWorkspace"
      }
    ],
    "configuration": {
      "title": "HitSimple",
      "properties": {
        "hitsimple.compilerPath": {
          "type": "string",
          "default": "hsc",
          "scope": "machine-overridable",
          "description": "Path or executable name for the HitSimple compiler. Executable names are resolved from the Extension Host PATH."
        },
        "hitsimple.mode": {
          "type": "string",
          "enum": [
            "unchecked",
            "static-checked",
            "checked"
          ],
          "enumDescriptions": [
            "Disable safety checks.",
            "Enable static safety diagnostics without runtime checks.",
            "Enable static and runtime safety checks."
          ],
          "default": "unchecked",
          "scope": "resource",
          "description": "Safety mode passed to hsc."
        },
        "hitsimple.outputDirectory": {
          "type": "string",
          "default": ".hitsimple/build",
          "scope": "resource",
          "description": "Build output directory. Relative paths are resolved from the current file's workspace folder and may not escape it."
        },
        "hitsimple.additionalArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional hsc arguments passed as individual argv entries without shell parsing."
        },
        "hitsimple.gdbPath": {
          "type": "string",
          "default": "gdb",
          "scope": "machine-overridable",
          "description": "Path or executable name for GDB used by Debug Current File."
        },
        "hitsimple.lldbPath": {
          "type": "string",
          "default": "lldb",
          "scope": "machine-overridable",
          "description": "Path or executable name for LLDB used by Debug Current File on macOS."
        },
        "hitsimple.debugArguments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Program arguments passed as individual argv entries when debugging."
        }
      }
    },
    "languages": [
      {
        "id": "hitsimple",
        "aliases": [
          "HitSimple",
          "hitsimple",
          "hs"
        ],
        "extensions": [
          ".hs",
          ".hsh",
          ".hsi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hitsimple",
        "scopeName": "source.hitsimple",
        "path": "./syntaxes/hitsimple.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "hitsimple",
        "path": "./snippets/hitsimple.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "hsc",
        "label": "HitSimple compiler diagnostics",
        "owner": "hitsimple",
        "source": "hsc",
        "applyTo": "allDocuments",
        "fileLocation": "autoDetect",
        "pattern": {
          "regexp": "^hsc: (.+):(\\d+):(\\d+): (?:cli|lexer|parser|sema|hir|codegen|runtime): (error|warning|note): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ]
  }
}
