{
  "main function": {
    "prefix": "main",
    "body": [
      "func main() {",
      "    ${1:// code}",
      "    return 0",
      "}"
    ],
    "description": "Create a HitSimple main function"
  },
  "function": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:arg[1]}) {",
      "    ${3:return 0}",
      "}"
    ],
    "description": "Create a HitSimple function"
  },
  "extern function": {
    "prefix": "externf",
    "body": [
      "extern ${1:name}(${2:arg[1]}) -> ${3:ret[1]}"
    ],
    "description": "Declare an external function"
  },
  "memory declaration": {
    "prefix": "new",
    "body": [
      "new ${1:name}[${2:1}]"
    ],
    "description": "Declare memory data"
  },
  "static memory declaration": {
    "prefix": "static",
    "body": [
      "static ${1:name}[${2:1}]"
    ],
    "description": "Declare static memory data"
  },
  "struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:member}[${3:1}]",
      "}"
    ],
    "description": "Create a struct definition"
  },
  "include guard": {
    "prefix": "guard",
    "body": [
      "$ ifndef ${1:HEADER_HSH_INCLUDED}",
      "$ define ${1:HEADER_HSH_INCLUDED}",
      "",
      "${2:// declarations}",
      "",
      "$ endif"
    ],
    "description": "Create a HitSimple preprocessor include guard"
  },
  "include": {
    "prefix": "include",
    "body": [
      "$ include ${1:<stdio.hsh>}"
    ],
    "description": "Add a HitSimple include directive"
  },
  "if statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "    ${2:// code}",
      "}"
    ],
    "description": "Create an if statement"
  },
  "while loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "    ${2:// code}",
      "}"
    ],
    "description": "Create a while loop"
  },
  "for loop": {
    "prefix": "for",
    "body": [
      "for (${1:new i[1] = 0}; ${2:i < 10}; ${3:i++}) {",
      "    ${4:// code}",
      "}"
    ],
    "description": "Create a for loop"
  },
  "try catch": {
    "prefix": "try",
    "body": [
      "try {",
      "    ${1:// code}",
      "} catch (${2:err}[${3:4}]) {",
      "    ${4:// handle error}",
      "}"
    ],
    "description": "Create a try/catch block"
  },
  "printf": {
    "prefix": "printf",
    "body": [
      "printf(\"${1:%d\\\\n}\", ${2:value})"
    ],
    "description": "Call printf with a literal format string"
  },
  "integer assignment": {
    "prefix": "%d=",
    "body": [
      "${1:name} %d= ${2:value}"
    ],
    "description": "Assign with integer interpretation"
  },
  "string assignment": {
    "prefix": "%s=",
    "body": [
      "${1:name} %s= \"${2:value}\""
    ],
    "description": "Assign with string interpretation"
  }
}
