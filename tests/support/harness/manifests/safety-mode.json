{
  "version": 2,
  "suite": "safety-mode",
  "defaults": {
    "targets": [
      "host"
    ],
    "safety": [
      "unchecked",
      "static-checked",
      "checked"
    ],
    "optimization": [
      "O0"
    ],
    "timeout_seconds": 10
  },
  "tests": [
    {
      "name": "hello_preserves_observable_behavior",
      "source": "../../../cases/run/hello.hs",
      "optimization": [
        "O0",
        "O2"
      ],
      "expect_by_mode": {
        "unchecked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run": {
            "exit_code": 0,
            "stdout": "42\n",
            "stderr": ""
          }
        },
        "static-checked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run": {
            "exit_code": 0,
            "stdout": "42\n",
            "stderr": ""
          }
        },
        "checked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run": {
            "exit_code": 0,
            "stdout": "42\n",
            "stderr": ""
          }
        }
      }
    },
    {
      "name": "dynamic_divide_by_zero",
      "source": "../../../cases/run/checked_dynamic_divide_by_zero.hs",
      "expect_by_mode": {
        "unchecked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run_not_applicable": "dynamic division by zero is undefined outside checked mode"
        },
        "static-checked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run_not_applicable": "dynamic division by zero is undefined outside checked mode"
        },
        "checked": {
          "compile": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
          },
          "run": {
            "exit_code": 120,
            "stdout": "",
            "stderr_regex": "^hitsimple runtime error: integer division by zero at .*/checked_dynamic_divide_by_zero\\.hs:7:12\\n$"
          }
        }
      }
    },
